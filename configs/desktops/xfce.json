{
  "packages": [
    "xfce-base/xfce4-meta",
    "x11-terms/xterm"
  ],
  "services": [
    "lightdm"
  ],
  "use_flags": [
    "X",
    "gtk",
    "xfce",
    "harfbuzz",
    "udisks",
    "gtk3"
  ],
  "desktop_environment": {
    "name": "xfce",
    "use_common_config": true,
    "customizations_path": "configs/custom_files/",
    "copy_files": [
      {
        "source": "desktops/xfce",
        "destination": "/etc/skel/.config/xfce4"
      }
    ]
  }
}
