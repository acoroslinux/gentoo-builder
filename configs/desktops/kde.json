{
  "packages": [
    "kde-plasma/plasma-meta",
    "kde-apps/konsole",
    "kde-apps/dolphin"
  ],
  "services": [
    "sddm"
  ],
  "use_flags": [
    "X",
    "plasma",
    "wayland",
    "qt5",
    "qt6",
    "kde",
    "policykit",
    "udisks"
  ],
  "desktop_environment": {
    "name": "kde",
    "use_common_config": true,
    "customizations_path": "configs/custom_files/",
    "copy_files": [
      {
        "source": "desktops/kde",
        "destination": "/etc/skel/.config"
      }
    ]
  }
}
