{
  "packages": [
    "mate-base/mate",
    "x11-terms/mate-terminal"
  ],
  "services": [
    "lightdm"
  ],
  "use_flags": [
    "X",
    "gtk",
    "gtk3",
    "mate"
  ],
  "desktop_environment": {
    "name": "mate",
    "use_common_config": true,
    "customizations_path": "configs/custom_files/",
    "copy_files": [
      {
        "source": "desktops/mate",
        "destination": "/etc/skel/.config/mate"
      }
    ]
  }
}
