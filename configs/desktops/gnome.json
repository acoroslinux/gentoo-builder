{
  "packages": [
    "gnome-base/gnome",
    "gnome-extra/gnome-tweaks"
  ],
  "services": [
    "gdm"
  ],
  "use_flags": [
    "X",
    "gnome",
    "wayland",
    "gtk",
    "gtk4",
    "systemd",
    "introspection",
    "policykit"
  ],
  "desktop_environment": {
    "name": "gnome",
    "use_common_config": true,
    "customizations_path": "configs/custom_files/",
    "copy_files": [
      {
        "source": "desktops/gnome",
        "destination": "/etc/skel/.config"
      }
    ]
  }
}
