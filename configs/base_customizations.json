{
  "base_copy_files": [
    {
      "source": "skel",
      "destination": "/etc/skel"
    },
    {
      "source": "applications",
      "destination": "/usr/share/applications"
    },
    {
      "source": "sudoers.d",
      "destination": "/etc/sudoers.d"
    },
    {
      "source": "backgrounds",
      "destination": "/usr/share/backgrounds"
    },
    {
      "source": "plymouth/themes/gentoo-modern",
      "destination": "/usr/share/plymouth/themes/gentoo-modern"
    },
    {
      "source": "plymouth/plymouthd.conf",
      "destination": "/etc/plymouth/plymouthd.conf"
    },
    {
      "source": "grub/modern",
      "destination": "/boot/grub/themes/modern"
    },
    {
      "source": "lightdm/lightdm-gtk-greeter.conf",
      "destination": "/etc/lightdm/lightdm-gtk-greeter.conf"
    },
    {
      "source": "sddm/sddm.conf.d",
      "destination": "/etc/sddm.conf.d"
    }
  ]
}
