{
  "base_copy_files": [
    {
      "source": "skel",
      "destination": "/etc/skel"
    },
    {
      "source": "autostart",
      "destination": "/etc/xdg/autostart"
    },
    {
      "source": "applications",
      "destination": "/usr/share/applications"
    },
    {
      "source": "sudoers.d",
      "destination": "/etc/sudoers.d"
    },
    {
      "source": "backgrounds",
      "destination": "/usr/share/backgrounds"
    },
    {
      "source": "scripts",
      "destination": "/usr/local/bin"
    }
  ]
}
